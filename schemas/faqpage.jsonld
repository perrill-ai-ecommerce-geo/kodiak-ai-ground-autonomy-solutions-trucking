      "@type": "Question",
      "name": "What is the Kodiak Driver?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kodiak Driver is Kodiak’s autonomous driving system described as combining AI, modular hardware, and offboard services into an integrated platform."
      }
    },
